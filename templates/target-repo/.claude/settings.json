{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "agent-harness": {
      "source": {
        "source": "github",
        "repo": "psumiya/agent-harness"
      }
    }
  },
  "enabledPlugins": {
    "core-workflow@agent-harness": true,
    "risk-review@agent-harness": true,
    "evals@agent-harness": true,
    "deploy-aws@agent-harness": true
  },
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue comment:*)"
    ],
    "deny": [
      "Bash(gh pr merge:*)",
      "Read(./.env)",
      "Read(./**/secrets/**)"
    ]
  }
}
